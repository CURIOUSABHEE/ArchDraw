{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@modelcontextprotocol/sdk/server/index.js": ["../frontend/node_modules/@modelcontextprotocol/sdk/dist/esm/server/index.d.ts"],
      "@modelcontextprotocol/sdk/server/stdio.js": ["../frontend/node_modules/@modelcontextprotocol/sdk/dist/esm/server/stdio.d.ts"],
      "@modelcontextprotocol/sdk/types.js": ["../frontend/node_modules/@modelcontextprotocol/sdk/dist/esm/types.d.ts"],
      "elkjs/lib/elk-api.js": ["../frontend/node_modules/elkjs/lib/elk-api.d.ts"],
      "elkjs/lib/elk.bundled.js": ["../frontend/node_modules/elkjs/lib/elk.bundled.d.ts"],
      "zod": ["../frontend/node_modules/zod/lib/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
